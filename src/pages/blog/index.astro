---
import Layout from '../../layouts/Layout.astro';

const title = 'JSON Guides — JSONKit';
const description =
  'In-depth guides on working with JSON: formatting, validation, conversion to YAML and CSV, JSON Schema, JSONPath, and more.';

const posts = [
  {
    slug: 'how-to-format-json-in-python',
    title: 'How to Format JSON in Python (Pretty-Print, Indent, Sort Keys)',
    description:
      'Three reliable ways to pretty-print JSON in Python — using json.dumps, the json.tool CLI, and a streaming approach for very large files.',
    date: '2026-04-30',
    readingMinutes: 6,
  },
  {
    slug: 'json-vs-yaml',
    title: 'JSON vs YAML: When to Use Which (with Real Examples)',
    description:
      'A practical comparison of JSON and YAML — syntax, readability, performance, tooling, and the specific cases where each format is the right choice.',
    date: '2026-04-30',
    readingMinutes: 7,
  },
  {
    slug: 'validate-json-with-json-schema',
    title: 'Validate JSON with JSON Schema: A Hands-On Guide',
    description:
      'Write your first JSON Schema, validate documents against it from Python, JavaScript, and the CLI, and avoid the most common pitfalls.',
    date: '2026-04-30',
    readingMinutes: 8,
  },
  {
    slug: 'json-to-csv-conversion-guide',
    title: 'Converting JSON to CSV: Flatten Nested Objects the Right Way',
    description:
      'Why naive JSON-to-CSV conversion breaks on nested fields, and three flattening strategies that produce a clean CSV ready for spreadsheets.',
    date: '2026-04-30',
    readingMinutes: 6,
  },
];
---

<Layout title={title} description={description}>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <header class="mb-12">
      <h1 class="text-balance text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl dark:text-white">
        JSON Guides
      </h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
        Practical articles on JSON, YAML, CSV, JSON Schema, and the everyday problems they solve.
      </p>
    </header>

    <ul class="space-y-8">
      {
        posts.map((post) => (
          <li class="border-b border-slate-200 pb-8 last:border-b-0 dark:border-slate-800">
            <a href={`/blog/${post.slug}`} class="group block">
              <p class="text-sm text-slate-500 dark:text-slate-400">
                <time datetime={post.date}>{post.date}</time> · {post.readingMinutes} min read
              </p>
              <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400">
                {post.title}
              </h2>
              <p class="mt-2 text-slate-600 dark:text-slate-400">{post.description}</p>
              <span class="mt-3 inline-flex items-center text-sm font-medium text-brand-600 group-hover:text-brand-700 dark:text-brand-400 dark:group-hover:text-brand-300">
                Read guide →
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
