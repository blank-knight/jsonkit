---
import Layout from '../../layouts/Layout.astro';

const title = 'JSON Diff — Compare Two JSON Documents Online | JSONKit';
const description =
  'Free online JSON diff tool. Compare two JSON documents structurally and see exactly what changed — added, removed, and modified keys. Runs in your browser.';
---

<Layout title={title} description={description}>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-slate-500 dark:text-slate-400">
      <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400">Home</a>
      <span class="mx-2">/</span>
      <a href="/#tools" class="hover:text-brand-600 dark:hover:text-brand-400">Tools</a>
      <span class="mx-2">/</span>
      <span class="text-slate-900 dark:text-white">JSON Diff</span>
    </nav>

    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
      JSON Diff
    </h1>
    <p class="mt-3 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
      Compare two JSON documents side by side. See what was added, removed, or modified with color-coded output.
    </p>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <button
        id="btn-diff"
        class="inline-flex items-center rounded-md bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
      >
        Compare
      </button>
      <button
        id="btn-swap"
        class="inline-flex items-center rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        ⇄ Swap
      </button>
      <button
        id="btn-clear"
        class="inline-flex items-center rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        Clear
      </button>
    </div>

    <div id="error-bar" class="mt-4 hidden rounded-md bg-red-50 px-4 py-3 text-sm text-red-700 dark:bg-red-900/30 dark:text-red-300" role="alert"></div>

    <!-- Summary -->
    <div id="summary" class="mt-3 hidden flex flex-wrap gap-4 text-sm font-medium">
      <span class="text-green-600 dark:text-green-400" id="added-count"></span>
      <span class="text-red-600 dark:text-red-400" id="removed-count"></span>
      <span class="text-amber-600 dark:text-amber-400" id="changed-count"></span>
    </div>

    <div class="mt-4 grid gap-4 lg:grid-cols-2">
      <div class="flex flex-col">
        <label for="json-left" class="mb-1.5 text-sm font-medium text-slate-700 dark:text-slate-300">Left (Original)</label>
        <textarea id="json-left" class="flex-1 min-h-[300px] rounded-lg border border-slate-200 bg-slate-50 p-4 font-mono text-sm leading-relaxed text-slate-900 placeholder-slate-400 focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:placeholder-slate-500" placeholder='First JSON...' spellcheck="false"></textarea>
      </div>
      <div class="flex flex-col">
        <label for="json-right" class="mb-1.5 text-sm font-medium text-slate-700 dark:text-slate-300">Right (Modified)</label>
        <textarea id="json-right" class="flex-1 min-h-[300px] rounded-lg border border-slate-200 bg-slate-50 p-4 font-mono text-sm leading-relaxed text-slate-900 placeholder-slate-400 focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:placeholder-slate-500" placeholder='Second JSON...' spellcheck="false"></textarea>
      </div>
    </div>

    <!-- Diff output -->
    <div id="diff-output" class="mt-6 hidden">
      <h2 class="mb-3 text-lg font-semibold text-slate-900 dark:text-white">Differences</h2>
      <div id="diff-content" class="rounded-lg border border-slate-200 bg-slate-50 p-4 font-mono text-sm leading-relaxed overflow-x-auto dark:border-slate-700 dark:bg-slate-900"></div>
    </div>

    <article class="mt-16 max-w-3xl space-y-6 text-slate-600 dark:text-slate-300">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">What is JSON Diff?</h2>
      <p>JSON Diff compares two JSON documents and highlights structural differences — keys that were added, removed, or whose values changed. Unlike text diff, it understands JSON semantics (key order doesn't matter).</p>
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Use cases</h2>
      <ul class="list-disc space-y-2 pl-6">
        <li>Compare API responses between environments (staging vs production).</li>
        <li>Review config file changes before deploying.</li>
        <li>Debug unexpected data differences in integration tests.</li>
      </ul>
      <p>All processing runs in your browser. Your data is never sent to any server.</p>
    </article>
  </section>
</Layout>

<script>
  const leftEl = document.getElementById('json-left') as HTMLTextAreaElement;
  const rightEl = document.getElementById('json-right') as HTMLTextAreaElement;
  const errorBar = document.getElementById('error-bar') as HTMLDivElement;
  const diffOutput = document.getElementById('diff-output') as HTMLDivElement;
  const diffContent = document.getElementById('diff-content') as HTMLDivElement;
  const summary = document.getElementById('summary') as HTMLDivElement;

  function showError(msg: string) { errorBar.textContent = msg; errorBar.classList.remove('hidden'); }
  function hideError() { errorBar.classList.add('hidden'); }

  function diffObjects(left: any, right: any, path: string = '$'): string[] {
    const lines: string[] = [];

    if (typeof left !== typeof right || left === null && right !== null || left !== null && right === null) {
      if (left !== undefined) lines.push(`<span class="text-red-600 dark:text-red-400">- ${path}: ${JSON.stringify(left)}</span>`);
      if (right !== undefined) lines.push(`<span class="text-green-600 dark:text-green-400">+ ${path}: ${JSON.stringify(right)}</span>`);
      return lines;
    }

    if (Array.isArray(left) && Array.isArray(right)) {
      const maxLen = Math.max(left.length, right.length);
      for (let i = 0; i < maxLen; i++) {
        const p = `${path}[${i}]`;
        if (i >= left.length) lines.push(`<span class="text-green-600 dark:text-green-400">+ ${p}: ${JSON.stringify(right[i])}</span>`);
        else if (i >= right.length) lines.push(`<span class="text-red-600 dark:text-red-400">- ${p}: ${JSON.stringify(left[i])}</span>`);
        else lines.push(...diffObjects(left[i], right[i], p));
      }
      return lines;
    }

    if (typeof left === 'object' && left !== null && typeof right === 'object' && right !== null) {
      const allKeys = new Set([...Object.keys(left), ...Object.keys(right)]);
      for (const key of allKeys) {
        const p = `${path}.${key}`;
        if (!(key in left)) lines.push(`<span class="text-green-600 dark:text-green-400">+ ${p}: ${JSON.stringify(right[key])}</span>`);
        else if (!(key in right)) lines.push(`<span class="text-red-600 dark:text-red-400">- ${p}: ${JSON.stringify(left[key])}</span>`);
        else lines.push(...diffObjects(left[key], right[key], p));
      }
      return lines;
    }

    // Primitives
    if (left !== right) {
      lines.push(`<span class="text-red-600 dark:text-red-400">- ${path}: ${JSON.stringify(left)}</span>`);
      lines.push(`<span class="text-green-600 dark:text-green-400">+ ${path}: ${JSON.stringify(right)}</span>`);
    }
    return lines;
  }

  function compare() {
    hideError();
    diffOutput.classList.add('hidden');
    summary.classList.add('hidden');

    const rawL = leftEl.value.trim();
    const rawR = rightEl.value.trim();
    if (!rawL || !rawR) { showError('Please paste JSON into both sides.'); return; }

    try {
      const left = JSON.parse(rawL);
      const right = JSON.parse(rawR);
      const result = diffObjects(left, right);

      if (result.length === 0) {
        diffContent.innerHTML = '<span class="text-green-600 dark:text-green-400">✓ The two JSON documents are identical.</span>';
      } else {
        diffContent.innerHTML = result.join('\n');

        const added = result.filter(l => l.includes('text-green')).length;
        const removed = result.filter(l => l.includes('text-red')).length;
        (document.getElementById('added-count')!).textContent = `+${added} added`;
        (document.getElementById('removed-count')!).textContent = `-${removed} removed`;
        summary.classList.remove('hidden');
      }
      diffOutput.classList.remove('hidden');
    } catch (err: any) {
      showError(err.message ?? 'Invalid JSON');
    }
  }

  document.getElementById('btn-diff')!.addEventListener('click', compare);
  document.getElementById('btn-swap')!.addEventListener('click', () => {
    const tmp = leftEl.value; leftEl.value = rightEl.value; rightEl.value = tmp;
  });
  document.getElementById('btn-clear')!.addEventListener('click', () => {
    leftEl.value = ''; rightEl.value = ''; hideError(); diffOutput.classList.add('hidden'); summary.classList.add('hidden');
  });
</script>
