---
import Layout from '../../layouts/Layout.astro';
import { tools } from '../../tools/registry';

const tool = tools.find((t) => t.slug === 'json-formatter')!;

const title = 'JSON Formatter — Pretty Print & Minify JSON Online | JSONKit';
const description =
  'Free online JSON formatter. Pretty-print JSON with 2/4/8-space indentation, minify JSON, and validate syntax instantly. No data leaves your browser.';
---

<Layout title={title} description={description}>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-slate-500 dark:text-slate-400">
      <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400">Home</a>
      <span class="mx-2">/</span>
      <a href="/#tools" class="hover:text-brand-600 dark:hover:text-brand-400">Tools</a>
      <span class="mx-2">/</span>
      <span class="text-slate-900 dark:text-white">JSON Formatter</span>
    </nav>

    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
      JSON Formatter
    </h1>
    <p class="mt-3 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
      Paste or type JSON below. Pretty-print with configurable indentation, minify to a single line,
      or validate syntax — all in your browser.
    </p>

    <!-- Controls -->
    <div class="mt-6 flex flex-wrap items-center gap-3">
      <button
        id="btn-format"
        class="inline-flex items-center rounded-md bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
      >
        Format
      </button>
      <button
        id="btn-minify"
        class="inline-flex items-center rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        Minify
      </button>
      <button
        id="btn-copy"
        class="inline-flex items-center rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1.5 h-4 w-4"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        Copy
      </button>
      <button
        id="btn-clear"
        class="inline-flex items-center rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        Clear
      </button>

      <div class="flex items-center gap-2 ml-auto">
        <label for="indent-select" class="text-sm text-slate-600 dark:text-slate-400">Indent:</label>
        <select
          id="indent-select"
          class="rounded-md border border-slate-200 bg-white px-2 py-1.5 text-sm text-slate-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200"
        >
          <option value="2">2 spaces</option>
          <option value="4" selected>4 spaces</option>
          <option value="8">8 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </div>
    </div>

    <!-- Error bar -->
    <div
      id="error-bar"
      class="mt-4 hidden rounded-md bg-red-50 px-4 py-3 text-sm text-red-700 dark:bg-red-900/30 dark:text-red-300"
      role="alert"
    ></div>

    <!-- Editors -->
    <div class="mt-4 grid gap-4 lg:grid-cols-2">
      <!-- Input -->
      <div class="flex flex-col">
        <label for="json-input" class="mb-1.5 text-sm font-medium text-slate-700 dark:text-slate-300">
          Input
        </label>
        <textarea
          id="json-input"
          class="flex-1 min-h-[350px] rounded-lg border border-slate-200 bg-slate-50 p-4 font-mono text-sm leading-relaxed text-slate-900 placeholder-slate-400 focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:placeholder-slate-500"
          placeholder='Paste JSON here, e.g. {"name":"JSONKit","version":"1.0"}'
          spellcheck="false"
        ></textarea>
      </div>

      <!-- Output -->
      <div class="flex flex-col">
        <label for="json-output" class="mb-1.5 text-sm font-medium text-slate-700 dark:text-slate-300">
          Output
        </label>
        <textarea
          id="json-output"
          readonly
          class="flex-1 min-h-[350px] rounded-lg border border-slate-200 bg-slate-50 p-4 font-mono text-sm leading-relaxed text-slate-900 placeholder-slate-400 focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:placeholder-slate-500"
          placeholder="Formatted output will appear here..."
          spellcheck="false"
        ></textarea>
      </div>
    </div>

    <!-- SEO Content below the tool -->
    <article class="mt-16 max-w-3xl space-y-6 text-slate-600 dark:text-slate-300">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">What is JSON Formatter?</h2>
      <p>
        A JSON formatter (also called a JSON beautifier or pretty printer) takes compact or messy JSON and
        reformats it with proper indentation and line breaks, making it easy for humans to read and debug.
      </p>

      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">How to use this tool</h2>
      <ol class="list-decimal space-y-2 pl-6">
        <li>Paste your JSON into the <strong>Input</strong> box on the left.</li>
        <li>Click <strong>Format</strong> to pretty-print, or <strong>Minify</strong> to compress.</li>
        <li>Adjust the indentation level (2, 4, 8 spaces, or tabs) with the dropdown.</li>
        <li>Use <strong>Copy</strong> to copy the result to your clipboard.</li>
      </ol>

      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Why use a JSON formatter?</h2>
      <ul class="list-disc space-y-2 pl-6">
        <li>Debug API responses that arrive as a single unreadable line.</li>
        <li>Validate JSON syntax — errors are highlighted with line and column info.</li>
        <li>Minify JSON to reduce file size for production deployments.</li>
        <li>Compare minified vs formatted JSON during development.</li>
      </ul>

      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Is my data safe?</h2>
      <p>
        Yes. All processing happens entirely in your browser using the built-in
        <code class="rounded bg-slate-100 px-1.5 py-0.5 text-sm dark:bg-slate-800">JSON.parse()</code> and
        <code class="rounded bg-slate-100 px-1.5 py-0.5 text-sm dark:bg-slate-800">JSON.stringify()</code> APIs.
        Your data is never sent to any server.
      </p>
    </article>
  </section>
</Layout>

<script>
  const input = document.getElementById('json-input') as HTMLTextAreaElement;
  const output = document.getElementById('json-output') as HTMLTextAreaElement;
  const errorBar = document.getElementById('error-bar') as HTMLDivElement;
  const indentSelect = document.getElementById('indent-select') as HTMLSelectElement;

  function showError(msg: string) {
    errorBar.textContent = msg;
    errorBar.classList.remove('hidden');
  }

  function hideError() {
    errorBar.classList.add('hidden');
    errorBar.textContent = '';
  }

  function getIndent(): string | number {
    const val = indentSelect.value;
    return val === 'tab' ? '\t' : parseInt(val, 10);
  }

  function format() {
    hideError();
    const raw = input.value.trim();
    if (!raw) {
      output.value = '';
      return;
    }
    try {
      const parsed = JSON.parse(raw);
      output.value = JSON.stringify(parsed, null, getIndent());
    } catch (err: any) {
      const match = err.message?.match(/position\s+(\d+)/i);
      let hint = err.message ?? 'Invalid JSON';
      if (match) {
        const pos = parseInt(match[1], 10);
        const before = raw.substring(0, pos);
        const line = (before.match(/\n/g) || []).length + 1;
        const col = pos - before.lastIndexOf('\n');
        hint += ` (line ${line}, column ${col})`;
      }
      showError(hint);
      output.value = '';
    }
  }

  function minify() {
    hideError();
    const raw = input.value.trim();
    if (!raw) {
      output.value = '';
      return;
    }
    try {
      const parsed = JSON.parse(raw);
      output.value = JSON.stringify(parsed);
    } catch (err: any) {
      showError(err.message ?? 'Invalid JSON');
      output.value = '';
    }
  }

  function copyOutput() {
    const text = output.value;
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('btn-copy')!;
      const original = btn.innerHTML;
      btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1.5 h-4 w-4"><polyline points="20 6 9 17 4 12"/></svg>Copied!';
      setTimeout(() => { btn.innerHTML = original; }, 1500);
    });
  }

  function clearAll() {
    input.value = '';
    output.value = '';
    hideError();
  }

  document.getElementById('btn-format')!.addEventListener('click', format);
  document.getElementById('btn-minify')!.addEventListener('click', minify);
  document.getElementById('btn-copy')!.addEventListener('click', copyOutput);
  document.getElementById('btn-clear')!.addEventListener('click', clearAll);

  // Auto-format on Ctrl/Cmd + Enter
  input.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
      e.preventDefault();
      format();
    }
  });
</script>
