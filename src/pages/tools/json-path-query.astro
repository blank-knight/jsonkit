---
import Layout from '../../layouts/Layout.astro';

const title = 'JSONPath Query — Extract Data from JSON Online | JSONKit';
const description =
  'Free online JSONPath query tool. Extract values from JSON documents using JSONPath expressions with live preview. Runs in your browser.';
---

<Layout title={title} description={description}>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-slate-500 dark:text-slate-400">
      <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400">Home</a>
      <span class="mx-2">/</span>
      <a href="/#tools" class="hover:text-brand-600 dark:hover:text-brand-400">Tools</a>
      <span class="mx-2">/</span>
      <span class="text-slate-900 dark:text-white">JSON Path Query</span>
    </nav>

    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
      JSONPath Query
    </h1>
    <p class="mt-3 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
      Query JSON documents using JSONPath expressions. See matching results in real-time as you type.
    </p>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <div class="flex-1 min-w-[250px]">
        <label for="path-input" class="sr-only">JSONPath expression</label>
        <input
          id="path-input"
          type="text"
          value="$.store.book[*].author"
          class="w-full rounded-md border border-slate-200 bg-white px-4 py-2 font-mono text-sm text-slate-900 placeholder-slate-400 focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
          placeholder="$.store.book[*].author"
          spellcheck="false"
        />
      </div>
      <button
        id="btn-query"
        class="inline-flex items-center rounded-md bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
      >
        Query
      </button>
      <button
        id="btn-copy"
        class="inline-flex items-center rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        Copy Results
      </button>
      <button
        id="btn-clear"
        class="inline-flex items-center rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        Clear
      </button>
    </div>

    <div id="error-bar" class="mt-4 hidden rounded-md bg-red-50 px-4 py-3 text-sm text-red-700 dark:bg-red-900/30 dark:text-red-300" role="alert"></div>

    <div id="match-count" class="mt-3 text-sm font-medium text-brand-600 dark:text-brand-400"></div>

    <div class="mt-4 grid gap-4 lg:grid-cols-2">
      <div class="flex flex-col">
        <label for="json-input" class="mb-1.5 text-sm font-medium text-slate-700 dark:text-slate-300">JSON Document</label>
        <textarea id="json-input" class="flex-1 min-h-[350px] rounded-lg border border-slate-200 bg-slate-50 p-4 font-mono text-sm leading-relaxed text-slate-900 placeholder-slate-400 focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:placeholder-slate-500" spellcheck="false" placeholder='Paste JSON here...'></textarea>
      </div>
      <div class="flex flex-col">
        <label for="query-output" class="mb-1.5 text-sm font-medium text-slate-700 dark:text-slate-300">Query Results</label>
        <textarea id="query-output" readonly class="flex-1 min-h-[350px] rounded-lg border border-slate-200 bg-slate-50 p-4 font-mono text-sm leading-relaxed text-slate-900 placeholder-slate-400 focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:placeholder-slate-500" placeholder="Results will appear here..." spellcheck="false"></textarea>
      </div>
    </div>

    <article class="mt-16 max-w-3xl space-y-6 text-slate-600 dark:text-slate-300">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">What is JSONPath?</h2>
      <p>JSONPath is a query language for JSON, similar to XPath for XML. It lets you extract specific values from complex nested JSON documents using concise expressions.</p>
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Common expressions</h2>
      <ul class="list-disc space-y-2 pl-6">
        <li><code class="rounded bg-slate-100 px-1 py-0.5 text-sm dark:bg-slate-800">$</code> — root element</li>
        <li><code class="rounded bg-slate-100 px-1 py-0.5 text-sm dark:bg-slate-800">$.store.book[0].title</code> — first book's title</li>
        <li><code class="rounded bg-slate-100 px-1 py-0.5 text-sm dark:bg-slate-800">$.store.book[*].author</code> — all authors</li>
        <li><code class="rounded bg-slate-100 px-1 py-0.5 text-sm dark:bg-slate-800">$..price</code> — all prices (recursive descent)</li>
        <li><code class="rounded bg-slate-100 px-1 py-0.5 text-sm dark:bg-slate-800">$.store.book[?(@.price &lt; 10)]</code> — filter books under $10</li>
      </ul>
      <p>All processing runs in your browser. Your data is never sent to any server.</p>
    </article>
  </section>
</Layout>

<script>
  import { JSONPath } from 'jsonpath-plus';

  const inputEl = document.getElementById('json-input') as HTMLTextAreaElement;
  const pathEl = document.getElementById('path-input') as HTMLInputElement;
  const outputEl = document.getElementById('query-output') as HTMLTextAreaElement;
  const errorBar = document.getElementById('error-bar') as HTMLDivElement;
  const matchCount = document.getElementById('match-count') as HTMLDivElement;

  function showError(msg: string) { errorBar.textContent = msg; errorBar.classList.remove('hidden'); }
  function hideError() { errorBar.classList.add('hidden'); }

  function query() {
    hideError();
    const raw = inputEl.value.trim();
    const path = pathEl.value.trim();
    if (!raw) { showError('Please paste JSON first.'); return; }
    if (!path) { showError('Please enter a JSONPath expression.'); return; }
    try {
      const obj = JSON.parse(raw);
      const result = JSONPath({ path, json: obj });
      outputEl.value = JSON.stringify(result, null, 2);
      matchCount.textContent = `${result.length} match${result.length === 1 ? '' : 'es'} found`;
    } catch (err: any) {
      showError(err.message ?? 'Query failed');
      outputEl.value = '';
      matchCount.textContent = '';
    }
  }

  function copy() {
    const t = outputEl.value; if (!t) return;
    navigator.clipboard.writeText(t).then(() => {
      const btn = document.getElementById('btn-copy')!;
      const orig = btn.textContent!; btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = orig; }, 1500);
    });
  }

  document.getElementById('btn-query')!.addEventListener('click', query);
  document.getElementById('btn-copy')!.addEventListener('click', copy);
  document.getElementById('btn-clear')!.addEventListener('click', () => { inputEl.value = ''; outputEl.value = ''; pathEl.value = '$'; hideError(); matchCount.textContent = ''; });
  pathEl.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); query(); } });
</script>
