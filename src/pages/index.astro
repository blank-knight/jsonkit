---
import Layout from '../layouts/Layout.astro';
import ToolCard from '../components/ToolCard.astro';
import { tools } from '../tools/registry';

const title = 'JSONKit — Free Online JSON Tools for Developers';
const description =
  'A free, fast, privacy-friendly suite of JSON tools: formatter, minifier, validator, JSON ↔ YAML / CSV converters, JSONPath query and JSON diff. All processing runs in your browser.';
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-b from-brand-50 via-white to-white dark:from-slate-900 dark:via-slate-950 dark:to-slate-950"
      aria-hidden="true"
    >
    </div>
    <div class="mx-auto max-w-6xl px-4 pt-16 pb-14 sm:px-6 sm:pt-20 lg:px-8 lg:pt-24">
      <div class="mx-auto max-w-3xl text-center">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-white px-3 py-1 text-xs font-medium text-brand-700 shadow-sm dark:border-brand-500/30 dark:bg-slate-900 dark:text-brand-300"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
          100% client-side · no data leaves your browser
        </span>
        <h1
          class="mt-6 text-balance text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl dark:text-white"
        >
          The JSON toolbox<br class="hidden sm:block" /> developers actually enjoy.
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600 dark:text-slate-300">
          Format, validate, transform, query and diff JSON — fast, private, and free.
          Every tool runs entirely in your browser, so your data never gets uploaded.
        </p>
        <div class="mt-8 flex items-center justify-center gap-3">
          <a
            href="/tools/json-formatter"
            class="inline-flex items-center justify-center rounded-md bg-brand-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-950"
          >
            Try JSON Formatter
          </a>
          <a
            href="#tools"
            class="inline-flex items-center justify-center rounded-md border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
          >
            Browse all tools
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools grid -->
  <section id="tools" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-end">
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl dark:text-white">
          All JSON tools
        </h2>
        <p class="mt-2 text-slate-600 dark:text-slate-400">
          A growing collection of focused, single-purpose utilities.
        </p>
      </div>
      <p class="text-sm text-slate-500 dark:text-slate-500">{tools.length} tools</p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        tools.map((tool) => (
          <ToolCard
            title={tool.title}
            description={tool.description}
            href={tool.href}
            icon={tool.icon}
            available={tool.available}
          />
        ))
      }
    </div>
  </section>

  <!-- About section -->
  <section id="about" class="border-t border-slate-200 bg-slate-50/60 dark:border-slate-800 dark:bg-slate-900/40">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="grid gap-10 md:grid-cols-3">
        <div>
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/10 text-brand-600 dark:text-brand-400">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900 dark:text-white">Privacy first</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
            Your JSON never leaves the browser. No accounts, no logs, no servers in the loop.
          </p>
        </div>
        <div>
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/10 text-brand-600 dark:text-brand-400">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900 dark:text-white">Instant &amp; offline</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
            Static pages, sub-second load. Once a tool loads, it works without a network.
          </p>
        </div>
        <div>
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/10 text-brand-600 dark:text-brand-400">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900 dark:text-white">Built for developers</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
            Keyboard-friendly, deep-linkable, and consistent across every tool in the kit.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
